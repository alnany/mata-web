{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "rm -rf node_modules apps/web/node_modules workers/matrix/node_modules packages/shared/node_modules && pnpm install --no-frozen-lockfile && MATA_ENABLE_E2EE=true NODE_OPTIONS=--max-old-space-size=7168 pnpm -r --filter=@mata/web build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon\\.svg|og-cover\\.jpg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/|favicon\\.svg|og-cover\\.jpg|sw\\.js).*)", "destination": "/index.html" }
  ]
}

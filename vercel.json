{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "rm -rf node_modules apps/web/node_modules workers/matrix/node_modules packages/shared/node_modules && pnpm install --frozen-lockfile && NODE_OPTIONS=--max-old-space-size=7168 pnpm -r --filter=@mata/web build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "trailingSlash": false,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
